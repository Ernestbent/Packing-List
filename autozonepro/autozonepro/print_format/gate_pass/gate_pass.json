 "html": "<!-- Gate Pass Print Format for ERPNext -->\n<!-- Paste into: Setup > Print Format > New > Type: Jinja -->\n<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 900px; margin: 0 auto; padding: 10px 24px 30px 24px;\">\n\n    <!-- Header -->\n    <div style=\"text-align: center; margin-bottom: 18px;\">\n        <h2 style=\"margin: 0; font-size: 26px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;\">\n            Gate Pass\n        </h2>\n        <p style=\"margin: 6px 0 0; font-size: 16px; font-weight: bold; color: #d32f2f;\">\n            {{ doc.name }}\n        </p>\n        <hr style=\"border: none; border-top: 2px solid #d4af37; width: 180px; margin: 10px auto 0;\">\n    </div>\n\n    <!-- Details \u2014 Only Date, Driver Name, Vehicle No, Mileage -->\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 22px; table-layout: fixed;\">\n        <colgroup>\n            <col style=\"width: 120px;\">\n            <col>\n            <col style=\"width: 120px;\">\n            <col>\n        </colgroup>\n        <tr>\n            <td style=\"font-weight: bold; padding: 4px 8px 4px 0;\">Date:</td>\n            <td style=\"padding: 4px 8px 4px 0; border-bottom: 1px solid #ccc;\">\n                {{ frappe.format(doc.date, {'fieldtype': 'Date'}) }}\n            </td>\n            <td style=\"font-weight: bold; padding: 4px 8px 4px 12px;\">Vehicle No:</td>\n            <td style=\"padding: 4px 0; border-bottom: 1px solid #ccc;\">\n                {{ doc.vehicle_no or '' }}\n            </td>\n        </tr>\n        <tr>\n            <td style=\"font-weight: bold; padding: 4px 8px 4px 0;\">Driver Name:</td>\n            <td style=\"padding: 4px 8px 4px 0; border-bottom: 1px solid #ccc;\">\n                {{ doc.driver_name or '' }}\n            </td>\n            <td style=\"font-weight: bold; padding: 4px 8px 4px 12px;\">Mileage:</td>\n            <td style=\"padding: 4px 0; border-bottom: 1px solid #ccc;\">\n                {{ doc.mileage or '' }}\n            </td>\n        </tr>\n    </table>\n\n    <!-- Items Section Title -->\n    <div style=\"font-size: 14px; font-weight: bold; margin-bottom: 8px;\">\n        Items / Goods Details\n    </div>\n\n    <!-- Items Table -->\n    <table style=\"width: 100%; border-collapse: collapse; border: 1px solid #ccc; table-layout: fixed; margin-bottom: 20px;\">\n        <colgroup>\n            <col style=\"width: 36px;\">\n            <col style=\"width: 18%;\">\n            <col>\n            <col style=\"width: 90px;\">\n            <col style=\"width: 75px;\">\n        </colgroup>\n        <thead>\n            <tr style=\"background: #f4f4f4;\">\n                <th style=\"padding: 7px 6px; border: 1px solid #ccc; text-align: center;\">#</th>\n                <th style=\"padding: 7px 6px; border: 1px solid #ccc; text-align: left;\">Sales Order</th>\n                <th style=\"padding: 7px 6px; border: 1px solid #ccc; text-align: left;\">Customer</th>\n                <th style=\"padding: 7px 6px; border: 1px solid #ccc; text-align: center;\">No of Boxes</th>\n                <th style=\"padding: 7px 6px; border: 1px solid #ccc; text-align: center;\">No of SKU</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.table_zcvy %}\n            <tr>\n                <td style=\"padding: 8px 6px; border: 1px solid #ccc; text-align: center; vertical-align: middle;\">\n                    {{ loop.index }}\n                </td>\n                <td style=\"padding: 8px 6px; border: 1px solid #ccc; vertical-align: middle; overflow-wrap: break-word; word-break: break-word;\">\n                    {{ item.sales_order or '' }}\n                </td>\n                <td style=\"padding: 8px 6px; border: 1px solid #ccc; vertical-align: middle; overflow-wrap: break-word; word-break: break-word; line-height: 1.5;\">\n                    {{ item.customer or '' }}\n                </td>\n                <td style=\"padding: 8px 6px; border: 1px solid #ccc; text-align: center; vertical-align: middle;\">\n                    {{ item.no_of_boxes or '' }}\n                </td>\n                <td style=\"padding: 8px 6px; border: 1px solid #ccc; text-align: center; vertical-align: middle;\">\n                    {{ item.no_of_sku or '' }}\n                </td>\n            </tr>\n            {% endfor %}\n            {% if not doc.table_zcvy %}\n            <tr>\n                <td colspan=\"5\" style=\"padding: 30px; text-align: center; color: #777; border: 1px solid #ccc;\">\n                    No items added to this gate pass\n                </td>\n            </tr>\n            {% endif %}\n        </tbody>\n    </table>\n\n    <!-- Remarks -->\n    {% if doc.remarks %}\n    <div style=\"margin-bottom: 20px;\">\n        <strong>Remarks:</strong>\n        <div style=\"border: 1px solid #ccc; background: #fafafa; padding: 10px 12px; min-height: 44px; margin-top: 6px; overflow-wrap: break-word; word-break: break-word;\">\n            {{ doc.remarks }}\n        </div>\n    </div>\n    {% endif %}\n\n    <!-- Signatures -->\n    <br><br>\n    <table style=\"width: 100%; margin-top: 40px; table-layout: fixed; border-collapse: collapse;\">\n        <tr>\n            <td style=\"width: 33.33%; text-align: center; padding: 0 10px 0 0;\">\n                <strong style=\"font-size: 12px;\">Authorised By</strong><br><br>\n                <div style=\"border-bottom: 1px solid #1a1a1a; margin: 0 10px;\"></div>\n            </td>\n            <td style=\"width: 33.33%; text-align: center; padding: 0 10px;\">\n                <strong style=\"font-size: 12px;\">Delivered By</strong><br><br>\n                <div style=\"border-bottom: 1px solid #1a1a1a; margin: 0 10px;\"></div>\n            </td>\n            <td style=\"width: 33.33%; text-align: center; padding: 0 0 0 10px;\">\n                <strong style=\"font-size: 12px;\">Security / Gate</strong><br><br>\n                <div style=\"border-bottom: 1px solid #1a1a1a; margin: 0 10px;\"></div>\n            </td>\n        </tr>\n    </table>\n\n    <!-- Footer rule -->\n    <div style=\"border-top: 2px solid #1a1a1a; margin-top: 36px;\"></div>\n\n</div>",
